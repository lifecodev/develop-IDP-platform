services:
  backstage-postgres:
    image: postgres:15-alpine
    container_name: backstage-postgres
    environment:
      POSTGRES_USER: backstage
      POSTGRES_PASSWORD: {{ backstage_db_password }}
      POSTGRES_DB: backstage_backend
    volumes:
      - pgdata:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U backstage -d backstage_backend"]
      interval: 5s
      timeout: 5s
      retries: 5

  backstage-backend:
    # Вместо несуществующего образа говорим собирать локальный Dockerfile
    build:
      context: ./my-app
      dockerfile: packages/backend/Dockerfile
    container_name: backstage-backend
    ports:
      - "3000:3000"
      - "7007:7007"
    environment:
      - NODE_ENV=production
      - AUTH_GITLAB_CLIENT_ID=<...>
      - AUTH_GITLAB_CLIENT_SECRET=<...>
      - AUTH_GITLAB_TOKEN=<...>
      - AUTH_SESSION_SECRET=just-test-secret-random-text
      - NODE_TLS_REJECT_UNAUTHORIZED=0
      - POSTGRES_HOST=backstage-postgres
      - POSTGRES_USER=backstage
      - POSTGRES_PASSWORD={{ backstage_db_password }}
    extra_hosts:
      - "gitlab.devops.local:172.16.30.2"
      - "backstage.devops.local:172.16.30.3"
    volumes:
      - ./app-config.production.yaml:/app/app-config.production.yaml
    depends_on:
      backstage-postgres:
        condition: service_healthy

volumes:
  pgdata:
